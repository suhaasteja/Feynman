# Copy relevant values into .env.local (git-ignored). Fill in as each stage needs them.

# --- Frontend (Vite) ---
# Written automatically by `npx convex dev`; do not set by hand.
VITE_CONVEX_URL=

# --- Convex deployment env (set via `npx convex env set NAME value`, NOT in this file) ---
# These live in the Convex deployment, not the frontend bundle. Set each with
# `npx convex env set NAME value`. Do NOT paste real keys into this file — it is
# committed to git.
#   OPENAI_API_KEY=<your-openai-key>          # OpenAI Realtime (Stage 3) + optional TTS
#   RESPAN_API_KEY=<your-respan-key>          # Respan gateway, base https://api.respan.ai/api (Stage 1 + 5)
#   ELEVENLABS_API_KEY=<your-elevenlabs-key>  # ElevenLabs narration TTS (Stage 2)
#   ELEVENLABS_VOICE_ID=<optional-voice-id>   # Optional preferred ElevenLabs voice.
